/* =============================================
   PORTFOLIO — Twenty-inspired Light Design
   Font: Gabarito (headings) + Inter (body)
   Palette: warm off-white, near-black text
   ============================================= */

/* ── Tokens ─────────────────────────────────── */
:root {
    --bg:          #FAFAF8;
    --bg-surface:  #FFFFFF;
    --bg-subtle:   #F5F5F2;
    --bg-muted:    #EDEDEA;

    --text:        #1A1A1A;
    --text-2:      #4A4A4A;
    --text-3:      #7A7A7A;
    --text-4:      #ABABAB;

    --border:      #E6E6E3;
    --border-light:#F0F0ED;

    --accent:      #1A1A1A;
    --accent-hover:#333333;
    --link:        #0055D4;

    --font-heading:'Gabarito', sans-serif;
    --font-body:   'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;

    --container:   1140px;
    --header-height: 64px;
    --radius:      12px;
    --radius-sm:   8px;
    --radius-xs:   6px;

    --ease:        cubic-bezier(.25,.46,.45,.94);
    --ease-out:    cubic-bezier(.16,1,.3,1);
    --duration:    .25s;
}

/* ── Reset ──────────────────────────────────── */
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

html {
    scroll-behavior: smooth;
    scroll-padding-top: calc(var(--header-height) + 24px);
    -webkit-text-size-adjust: 100%;
}

body {
    font-family: var(--font-body);
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
}

img, svg { display:block; max-width:100%; }
a { color:inherit; text-decoration:none; }
button { font:inherit; cursor:pointer; border:none; background:none; }
ul, ol { list-style:none; }

/* ── Utility ────────────────────────────────── */
.container {
    width: 100%;
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 24px;
}

/* Focus-visible ring */
:focus-visible {
    outline: 2px solid var(--link);
    outline-offset: 2px;
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
        animation-duration: 0.01ms !important;
        transition-duration: 0.01ms !important;
    }
    html { scroll-behavior: auto; }
}

/* ── Scroll animation base ──────────────────── */
.reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity .6s var(--ease-out), transform .6s var(--ease-out);
}
.reveal.visible {
    opacity: 1;
    transform: translateY(0);
}

/* =============================================
   HEADER
   ============================================= */
.header {
    position: fixed;
    inset: 0 0 auto;
    z-index: 100;
    height: var(--header-height);
    background: rgba(250, 250, 248, .85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid transparent;
    transition: border-color var(--duration) var(--ease), box-shadow var(--duration) var(--ease);
}
.header.scrolled {
    border-bottom-color: var(--border);
    box-shadow: 0 1px 8px rgba(0,0,0,.04);
}

.nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    gap: 32px;
}

.logo {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--text);
    white-space: nowrap;
    letter-spacing: -.01em;
}

.nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
}
.nav-links a {
    font-size: .9rem;
    font-weight: 500;
    color: var(--text-3);
    transition: color var(--duration) var(--ease);
}
.nav-links a:hover { color: var(--text); }

.nav-actions {
    display: flex;
    align-items: center;
    gap: 16px;
}

.nav-cta {
    display: inline-flex;
    align-items: center;
    padding: 8px 20px;
    font-size: .875rem;
    font-weight: 600;
    color: #fff;
    background: var(--accent);
    border-radius: 999px;
    transition: background var(--duration) var(--ease), transform .15s var(--ease);
}
.nav-cta:hover {
    background: var(--accent-hover);
}

/* Mobile toggle */
.mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 8px;
    width: 36px;
}
.mobile-toggle span {
    display: block;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: transform .3s var(--ease), opacity .2s;
}
.mobile-toggle.active span:first-child {
    transform: translateY(3.5px) rotate(45deg);
}
.mobile-toggle.active span:last-child {
    transform: translateY(-3.5px) rotate(-45deg);
}

/* =============================================
   HERO
   ============================================= */
.hero {
    padding: calc(var(--header-height) + 80px) 0 60px;
    text-align: center;
}

.hero-container {
    max-width: 820px;
}

.hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    font-size: .8125rem;
    font-weight: 500;
    color: var(--text-2);
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    margin-bottom: 32px;
}
.badge-dot {
    width: 8px;
    height: 8px;
    background: #22c55e;
    border-radius: 50%;
    animation: pulse-dot 2s ease-in-out infinite;
}
@keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: .6; transform: scale(1.3); }
}

.hero-heading {
    font-family: var(--font-heading);
    font-size: clamp(2.75rem, 5.5vw, 4.75rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -.025em;
    color: var(--text);
    margin-bottom: 24px;
}

.hero-sub {
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    line-height: 1.65;
    color: var(--text-2);
    max-width: 600px;
    margin: 0 auto 40px;
}

.hero-actions {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
}

/* ── Buttons ────────────────────────────────── */
.btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 28px;
    font-size: .9375rem;
    font-weight: 600;
    border-radius: 999px;
    transition: all var(--duration) var(--ease);
    white-space: nowrap;
}
.btn svg { flex-shrink:0; }

.btn-dark {
    color: #fff;
    background: var(--accent);
}
.btn-dark:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(0,0,0,.12);
}

.btn-outline {
    color: var(--text);
    border: 1.5px solid var(--border);
    background: var(--bg-surface);
}
.btn-outline:hover {
    border-color: var(--text-4);
    background: var(--bg-subtle);
}

.btn-lg {
    padding: 16px 36px;
    font-size: 1rem;
}

/* =============================================
   STATS
   ============================================= */
.stats {
    padding: 48px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--bg-surface);
}

.stats-row {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 40px;
    flex-wrap: wrap;
}

.stat-item {
    text-align: center;
}
.stat-number {
    display: block;
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    color: var(--text);
    letter-spacing: -.02em;
}
.stat-label {
    display: block;
    font-size: .8125rem;
    color: var(--text-3);
    margin-top: 4px;
}

.stat-divider {
    width: 1px;
    height: 40px;
    background: var(--border);
}

/* =============================================
   LOGOS
   ============================================= */
.logos-section {
    padding: 56px 0;
}

.logos-label {
    text-align: center;
    font-size: .8125rem;
    font-weight: 500;
    color: var(--text-4);
    text-transform: uppercase;
    letter-spacing: .06em;
    margin-bottom: 28px;
}

.logos-row {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 40px;
    flex-wrap: wrap;
}

.logo-item {
    font-size: .9375rem;
    font-weight: 600;
    color: var(--text-3);
    display: flex;
    align-items: center;
    gap: 8px;
    transition: color var(--duration) var(--ease);
}
.logo-item:hover { color: var(--text); }
.logo-item img {
    width: 24px;
    height: 24px;
    object-fit: contain;
    border-radius: 4px;
}

/* =============================================
   SECTION COMMON
   ============================================= */
.about, .experience, .projects, .skills, .testimonials, .education, .contact {
    padding: 100px 0;
}
.about, .skills, .education {
    background: var(--bg-surface);
}

.section-header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 64px;
}

.section-heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -.02em;
    color: var(--text);
    margin-bottom: 16px;
}

.section-desc {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--text-2);
}

/* =============================================
   FEATURES / ABOUT
   ============================================= */
.features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
}

.feature-card {
    padding: 32px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    transition: border-color var(--duration) var(--ease), box-shadow var(--duration) var(--ease);
}
.feature-card:hover {
    border-color: var(--text-4);
    box-shadow: 0 8px 32px rgba(0,0,0,.05);
}

.feature-card .feature-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: .875rem;
    background: var(--text);
    color: #fff;
    border-radius: 999px;
    margin-bottom: 20px;
}

.feature-card h3 {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--text);
}

.feature-card p {
    color: var(--text-2);
    font-size: .9375rem;
    line-height: 1.65;
    margin-bottom: 20px;
}

.feature-link {
    font-size: .875rem;
    font-weight: 600;
    color: var(--text);
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: gap var(--duration) var(--ease);
}
.feature-link:hover {
    gap: 8px;
}
.feature-link::after {
    content: '\2192';
}

/* =============================================
   EXPERIENCE
   ============================================= */
.exp-list {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
}

.exp-card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-surface);
    padding: 32px;
    transition: border-color var(--duration) var(--ease), box-shadow var(--duration) var(--ease);
}
.exp-card:hover {
    border-color: var(--text-4);
    box-shadow: 0 8px 32px rgba(0,0,0,.05);
}

.exp-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
    flex-wrap: wrap;
}
.exp-header-left {
    display: flex;
    align-items: center;
    gap: 12px;
}
.exp-company-icon {
    width: 40px;
    height: 40px;
    object-fit: contain;
    border-radius: var(--radius-xs);
    border: 1px solid var(--border-light);
}
.exp-header h3 {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
}
.exp-role {
    font-size: .9rem;
    color: var(--text-2);
}
.exp-duration {
    font-size: .8125rem;
    color: var(--text-3);
    font-weight: 500;
    white-space: nowrap;
    padding-top: 4px;
}

.exp-achievements {
    margin-bottom: 20px;
}
.exp-achievements li {
    position: relative;
    padding-left: 20px;
    margin-bottom: 10px;
    font-size: .9375rem;
    line-height: 1.6;
    color: var(--text-2);
}
.exp-achievements li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 6px;
    height: 6px;
    background: var(--text-4);
    border-radius: 50%;
}

.exp-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
}
.exp-tags span {
    padding: 4px 12px;
    font-size: .8125rem;
    font-weight: 500;
    color: var(--text-2);
    background: var(--bg-subtle);
    border-radius: 999px;
}

/* =============================================
   PROJECTS
   ============================================= */
.projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 24px;
}

.project-card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-surface);
    padding: 28px;
    display: flex;
    flex-direction: column;
    transition: border-color var(--duration) var(--ease), box-shadow var(--duration) var(--ease);
}
.project-card:hover {
    border-color: var(--text-4);
    box-shadow: 0 8px 32px rgba(0,0,0,.05);
}

.project-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
}
.project-icon {
    font-size: 1.5rem;
}
.project-gh {
    display: flex;
    align-items: center;
    color: var(--text-3);
    transition: color var(--duration);
}
.project-gh:hover { color: var(--text); }

.project-card h3 {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 10px;
    color: var(--text);
}

.project-card .project-desc {
    font-size: .9375rem;
    color: var(--text-2);
    line-height: 1.6;
    margin-bottom: 20px;
    flex: 1;
}

.project-card .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
}
.project-card .tech-tags span {
    padding: 4px 10px;
    font-size: .75rem;
    font-weight: 500;
    color: var(--text-3);
    background: var(--bg-subtle);
    border-radius: 999px;
}

/* =============================================
   SKILLS
   ============================================= */
.skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 24px;
    max-width: 960px;
    margin: 0 auto;
}

.skill-category {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    padding: 28px;
}
.skill-category h3 {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 20px;
}

.skill-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
}

.skill-item {
    display: flex;
    align-items: center;
    gap: 12px;
}
.skill-name {
    flex-shrink: 0;
    width: 130px;
    font-size: .8375rem;
    color: var(--text-2);
}
.skill-bar {
    flex: 1;
    height: 6px;
    background: var(--bg-muted);
    border-radius: 999px;
    overflow: hidden;
}
.skill-fill {
    height: 100%;
    background: var(--text);
    border-radius: 999px;
    transition: width 1s var(--ease-out);
}

/* =============================================
   TESTIMONIALS
   ============================================= */
.testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
    max-width: 1000px;
    margin: 0 auto;
}

.testimonial-card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-surface);
    padding: 32px;
    transition: border-color var(--duration) var(--ease), box-shadow var(--duration) var(--ease);
}
.testimonial-card:hover {
    border-color: var(--text-4);
    box-shadow: 0 8px 32px rgba(0,0,0,.05);
}

.testimonial-card blockquote {
    font-size: .9375rem;
    line-height: 1.7;
    color: var(--text-2);
    margin-bottom: 24px;
    font-style: normal;
}
.testimonial-card blockquote::before {
    content: '\201C';
    display: block;
    font-family: var(--font-heading);
    font-size: 2.5rem;
    line-height: 1;
    color: var(--text-4);
    margin-bottom: 8px;
}

.testimonial-author {
    display: flex;
    flex-direction: column;
    gap: 2px;
}
.author-name {
    font-weight: 600;
    font-size: .9rem;
    color: var(--text);
}
.author-role {
    font-size: .8125rem;
    color: var(--text-3);
}

/* =============================================
   EDUCATION
   ============================================= */
.edu-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    max-width: 880px;
    margin: 0 auto;
}

.edu-card {
    display: flex;
    gap: 16px;
    padding: 28px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    transition: border-color var(--duration) var(--ease);
}
.edu-card:hover {
    border-color: var(--text-4);
}

.edu-icon {
    font-size: 1.75rem;
    flex-shrink: 0;
    line-height: 1;
}

.edu-body h3 {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 4px;
}
.edu-degree {
    font-size: .875rem;
    color: var(--text-2);
    margin-bottom: 4px;
}
.edu-meta {
    font-size: .8125rem;
    color: var(--text-3);
    margin-bottom: 8px;
}
.edu-detail {
    font-size: .8125rem;
    color: var(--text-3);
    line-height: 1.5;
}

/* =============================================
   CONTACT
   ============================================= */
.contact {
    background: var(--bg-surface);
}

.contact-inner {
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
}

.contact-desc {
    font-size: 1.0625rem;
    color: var(--text-2);
    line-height: 1.65;
    margin-bottom: 48px;
}

.contact-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 48px;
}

.contact-card {
    padding: 24px 16px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    text-align: center;
    transition: border-color var(--duration) var(--ease);
}
.contact-card:hover {
    border-color: var(--text-4);
}

.contact-card .c-icon {
    font-size: 1.5rem;
    margin-bottom: 12px;
}
.contact-card h3 {
    font-family: var(--font-heading);
    font-size: .875rem;
    font-weight: 700;
    margin-bottom: 6px;
    color: var(--text);
}
.contact-card a {
    font-size: .8125rem;
    color: var(--link);
    word-break: break-all;
}
.contact-card a:hover {
    text-decoration: underline;
}

.contact-cta {
    margin-top: 8px;
}

/* =============================================
   FOOTER
   ============================================= */
.footer {
    padding: 64px 0 40px;
    border-top: 1px solid var(--border);
}

.footer-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 40px;
    margin-bottom: 48px;
}

.footer-logo {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--text);
}
.footer-tagline {
    font-size: .8125rem;
    color: var(--text-3);
    margin-top: 6px;
}

.footer-col h4 {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: .875rem;
    color: var(--text);
    margin-bottom: 14px;
}

.footer-nav,
.footer-connect {
    display: flex;
    flex-direction: column;
    gap: 10px;
}
.footer-nav a,
.footer-connect a {
    font-size: .875rem;
    color: var(--text-3);
    transition: color var(--duration);
}
.footer-nav a:hover,
.footer-connect a:hover {
    color: var(--text);
}

.footer-location {
    font-size: .875rem;
    color: var(--text-3);
}

.footer-bottom {
    padding-top: 24px;
    border-top: 1px solid var(--border);
}
.footer-bottom p {
    font-size: .8125rem;
    color: var(--text-4);
}

/* =============================================
   RESPONSIVE
   ============================================= */
@media (max-width: 1024px) {
    .features-grid {
        grid-template-columns: 1fr;
        max-width: 540px;
        margin-left: auto;
        margin-right: auto;
    }
    .footer-top {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 768px) {
    :root {
        --header-height: 56px;
    }

    .nav-links {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        height: calc(100vh - var(--header-height));
        height: calc(100dvh - var(--header-height));
        background: var(--bg);
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 32px 24px;
        gap: 28px;
        z-index: 99;
        border-top: 1px solid var(--border);
        overflow-y: auto;
    }
    .nav-links.active {
        display: flex;
    }
    .nav-links a {
        font-size: 1.5rem;
        font-weight: 600;
        padding: 8px 0;
        color: var(--text-2);
    }
    .nav-links a:hover {
        color: var(--text);
    }

    .nav-cta { display: none; }
    .mobile-toggle { display: flex; }

    .hero {
        padding-top: calc(var(--header-height) + 48px);
        padding-bottom: 40px;
    }
    .hero-heading {
        font-size: clamp(2rem, 8vw, 3rem);
    }

    .stats-row {
        gap: 24px;
    }
    .stat-divider { display:none; }
    .stats-row {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
    }

    .about, .experience, .projects, .skills, .testimonials, .education, .contact {
        padding: 64px 0;
    }

    .section-heading {
        font-size: clamp(1.75rem, 6vw, 2.5rem);
    }
    .section-header {
        margin-bottom: 40px;
    }

    .exp-header {
        flex-direction: column;
        gap: 8px;
    }
    .exp-duration {
        padding-top: 0;
    }

    .projects-grid {
        grid-template-columns: 1fr;
    }

    .skills-grid {
        grid-template-columns: 1fr;
    }

    .testimonials-grid {
        grid-template-columns: 1fr;
    }

    .edu-grid {
        grid-template-columns: 1fr;
    }

    .contact-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .footer-top {
        grid-template-columns: 1fr;
        gap: 32px;
    }
}

@media (max-width: 640px) {
    .contact-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 480px) {
    .container { padding: 0 16px; }

    .hero-actions {
        flex-direction: column;
        align-items: center;
    }
    .hero-actions .btn {
        width: 100%;
        max-width: 280px;
        justify-content: center;
    }

    .stats-row {
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .logos-row {
        gap: 20px;
    }

    .contact-grid {
        grid-template-columns: 1fr;
    }

    .skill-name {
        width: 100px;
        font-size: .8rem;
    }
}
